# ---------------------------------------------------------------------------
# Filzy environment. Copy this file to `.env` and fill in the values.
# `.env` is gitignored — never commit real credentials.
# All keys are VITE_-prefixed so Vite exposes them to the browser at build time.
# ---------------------------------------------------------------------------

# --- Beam TURN relay (fixes "Can't reach the sender" across networks) --------
# STUN alone (built in, free) connects peers on friendly NATs / same Wi-Fi.
# Cross-network beams (one side on cellular, strict/symmetric NAT) need a TURN
# relay. The old free public relay was shut down, so bring your own — it's free.
#
# Metered free tier (simplest, ~50GB/mo):
#   1. Sign up at https://dashboard.metered.ca -> TURN Server
#   2. Create an app, copy the username + password it shows
#   3. Paste them below. That's it — no other code needed.
VITE_TURN_USER=
VITE_TURN_CRED=
# Only set if your Metered dashboard shows a host other than the default.
# VITE_TURN_HOST=global.relay.metered.ca

# --- Optional: a single custom relay (e.g. Cloudflare TURN, later) -----------
# Added alongside the Metered endpoints above; reuses VITE_TURN_USER/CRED.
# VITE_TURN_URL=

# --- Optional: your own WebSocket signaling endpoint -------------------------
# If unset, Filzy uses BroadcastChannel (same browser) + a public MQTT broker
# (cross-device). Set this only if you run a dedicated signaling server.
# VITE_SIGNAL_URL=
